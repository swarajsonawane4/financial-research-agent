# Copy this file to `.env` and fill in whichever LLM you choose to use.
# The Day 1 loop runs WITHOUT any of these (mock mode), so none are required yet.

# --- Pick ONE LLM provider (optional until Day 4) ---
# Free, generous tier — recommended to start:
GEMINI_API_KEY=

# Or OpenAI (cheap with gpt-4o-mini):
OPENAI_API_KEY=

# Or Anthropic:
ANTHROPIC_API_KEY=

# --- Optional data-source keys (free tiers; needed from Day 5) ---
# SEC EDGAR needs NO key. These are for other tools:
TAVILY_API_KEY=          # web search (1,000 free searches/month)
FMP_API_KEY=             # Financial Modeling Prep (250 req/day free)
ALPHA_VANTAGE_API_KEY=   # Alpha Vantage (25 req/day free)
